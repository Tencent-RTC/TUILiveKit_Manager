# =============================================
# 腾讯云应用配置（必填）
# =============================================
# 从 IM 控制台获取: https://console.cloud.tencent.com/im
SDK_APP_ID=your_sdk_app_id
SECRET_KEY=your_secret_key

# 腾讯云 API 密钥（必填）
# 从 访问管理 控制台获取: https://console.cloud.tencent.com/cam/capi
TENCENT_CLOUD_SECRET_ID=your_tencent_cloud_secret_id
TENCENT_CLOUD_SECRET_KEY=your_tencent_cloud_secret_key

# 管理员账号
USER_ID=administrator
PORT=9000

# =============================================
# 违规标签轮询配置
# =============================================
# 违规标签刷新间隔（秒），默认 600（10 分钟）
LIVE_VIOLATION_REFRESH_INTERVAL=30

# =============================================
# 腾讯云 API 域名配置
# =============================================
# IM API 域名（直播 IM 账号导入等功能）
# 中国：console.tim.qq.com
# 新加坡：adminapisgp.im.qcloud.com
# 首尔：adminapikr.im.qcloud.com
# 法兰克福：adminapiger.im.qcloud.com
# 美国：adminapiusa.im.qcloud.com
# 印尼：adminapiidn.im.qcloud.com
DOMAIN_CLOUD_API_IM=im.tencentcloudapi.com

# TRTC API 域名（房间查询等功能）
# 正式环境：trtc.tencentcloudapi.com
# 其他区域请根据腾讯云文档配置
DOMAIN_CLOUD_API_TRTC=trtc.tencentcloudapi.com

# =============================================
# 存储 Provider 配置（图片上传功能）
# =============================================
# 选择存储后端类型，可选值: cos | custom
# - cos    : 腾讯云 COS 对象存储
# - custom : 自定义 HTTP 上传接口
# 不配置此项则完全禁用存储上传功能，前端无法上传文件
STORAGE_PROVIDER=cos

# ---------- COS 配置（STORAGE_PROVIDER=cos 时使用） ----------
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your_bucket_name
COS_REGION=ap-hongkong
# CDN 加速域名（可选，不配置则使用默认 COS 域名）
COS_CDN_DOMAIN=https://your-cdn-domain.com
# 存储路径前缀（可选，文件存储在此目录下）
COS_PATH_PREFIX=trtc/livekit/monitor/demo/upload

# ---------- 自定义 Provider 配置（STORAGE_PROVIDER=custom 时使用） ----------
# 上传接口地址（必填），将以 multipart/form-data 方式 POST 文件
# CUSTOM_UPLOAD_URL=https://your-api.com/upload
# 文件访问域名前缀（可选，当无法从接口响应提取 URL 时用于拼接）
# CUSTOM_ACCESS_DOMAIN=https://cdn.your-api.com
# 上传接口的文件字段名（默认: file）
# CUSTOM_UPLOAD_FIELD=file
# 接口响应中 URL 字段的 JSON 路径，支持点分路径（默认: data.url）
# CUSTOM_RESPONSE_URL_FIELD=data.url
# 自定义认证请求头（可选，格式: "Header-Name: Header-Value"）
# CUSTOM_AUTH_HEADER=Authorization: Bearer your_token
# 存储路径前缀（可选）
# CUSTOM_PATH_PREFIX=uploads

# =============================================
# 扩展自定义 Provider 指引
# =============================================
# 如果需要接入 AWS S3、阿里云 OSS 等其他存储服务，按以下步骤操作：
#
# 1. 在 server/src/services/storage/ 下创建 YourProvider.js
#    继承 StorageProvider 基类并实现以下方法：
#    - isEnabled()               检查是否配置完整
#    - getConfig()               返回前端可用的配置信息（不含密钥）
#    - uploadFile(buffer, key, contentType)  上传文件，返回 { url, key }
#    - deleteFile(key)           删除文件（可选）
#
# 2. 在 server/src/services/storage/index.js 的 PROVIDER_MAP 中注册：
#    const YourProvider = require('./YourProvider');
#    const PROVIDER_MAP = { cos: CosProvider, custom: CustomProvider, your_key: YourProvider };
#
# 3. 在本文件中设置 STORAGE_PROVIDER=your_key 并添加对应的配置项

# =============================================
# 审核模式配置
# =============================================
# 选择审核模式，可选值: cloud | custom
# - cloud  : 腾讯云 IM 云端审核（默认）
# - custom : 用户自有审核服务器（需配置下方 CUSTOM_MODERATION_* 参数）
MODERATION_MODE=cloud

# ---------- 用户自有审核服务器配置（MODERATION_MODE=custom 时使用） ----------
# 用户自有审核服务器的 Base URL
CUSTOM_MODERATION_BASE_URL=http://localhost:9001
# API Key 用于调用用户审核服务器（可选，不配则不传）
# CUSTOM_MODERATION_API_KEY=your_api_key_here
