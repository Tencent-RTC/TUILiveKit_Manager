# Custom Moderation Server 配置文件
#
# 将本文件复制为 .env 后按需修改：
#   cp config/example.env config/.env

# 服务端口（默认 9001）
PORT=9001

# IM 回调路径（默认 /im-callback）
CALLBACK_PATH=/im-callback

# API Key（可选，留空则跳过 API 认证）
API_KEY=

# 数据库文件路径（可选，默认 data/moderation.db）
# 支持绝对路径（方便挂载卷）和相对路径（相对项目根目录）
# DB_PATH=data/moderation.db
